generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Team {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  code        String      @unique
  flag        String
  groupName   String
  goals       GoalEvent[]
  awayMatches Match[]     @relation("AwayTeam")
  homeMatches Match[]     @relation("HomeTeam")
}

model Match {
  id              Int          @id @default(autoincrement())
  matchNumber     Int          @unique
  date            String
  time            String
  stage           String
  venue           String
  city            String
  homeTeamId      Int?
  awayTeamId      Int?
  homePlaceholder String?
  awayPlaceholder String?
  scoreHome       Int?
  scoreAway       Int?
  status          String       @default("scheduled")
  summary         String?
  goals           GoalEvent[]
  highlights      Highlight[]
  predictions     Prediction[]
  awayTeam        Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam        Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
}

model GoalEvent {
  id          Int     @id @default(autoincrement())
  matchId     Int
  teamId      Int
  playerName  String
  minute      Int
  minuteExtra Int?
  assistName  String?
  goalType    String  @default("goal")
  match       Match   @relation(fields: [matchId], references: [id])
  team        Team    @relation(fields: [teamId], references: [id])
}

model Highlight {
  id          Int     @id @default(autoincrement())
  matchId     Int
  title       String
  description String?
  minute      Int?
  videoUrl    String?
  type        String  @default("moment")
  source      String  @default("editorial")
  subreddit   String?
  upvotes     Int?
  redditUrl   String?
  match       Match   @relation(fields: [matchId], references: [id])
}

model Prediction {
  id            Int    @id @default(autoincrement())
  matchId       Int
  visitorId     String
  predictedHome Int
  predictedAway Int
  createdAt     DateTime @default(now())
  match         Match  @relation(fields: [matchId], references: [id])

  @@unique([matchId, visitorId])
}

model WatchParty {
  id          Int      @id @default(autoincrement())
  city        String
  country     String   @default("US")
  venueName   String
  address     String?
  description String?
  teamFanbase String?
  submittedBy String?
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())
}
